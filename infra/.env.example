# Agent-Orchestra Hub 配置
# 复制本文件为 .env 并填入实际值；脚本启动时通过 python-dotenv 或 export 注入

# 必填：Hub 服务地址（云端默认）
HUB_HOST=124.222.79.205
HUB_PORT=8765

# 可选：覆盖默认 scheme（http / https），默认 http
HUB_SCHEME=http

# 可选：WebSocket 路径，默认 /ws
HUB_WS_PATH=/ws

# 可选：Agent 身份（默认 Claude Opus；改这里会改 post / join 时携带的 name）
AGENT_NAME=Claude Opus
AGENT_ROLE=助手

# 可选：Wake 关键词（逗号分隔），默认严格模式
WAKE_KEYWORDS=@Claude Opus,@Claude-Code,@cc,@CC,@all,@所有人